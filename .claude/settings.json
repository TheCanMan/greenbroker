{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(curl -s:*)",
      "Bash(curl -sL:*)",
      "Bash(curl -X:*)",

      "Bash(npm run deploy:cf)",
      "Bash(npm run dev)",
      "Bash(npm run db:generate)",
      "Bash(npm run db:push)",
      "Bash(npm run db:seed)",
      "Bash(npm run type-check)",
      "Bash(npm install)",

      "Bash(npx tsc:*)",
      "Bash(npx next build)",
      "Bash(npx next build:*)",
      "Bash(npx next lint)",
      "Bash(npx next lint:*)",
      "Bash(npx wrangler deployments list:*)",
      "Bash(npx wrangler secret list:*)",
      "Bash(npx wrangler tail:*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma format)",
      "Bash(npx prisma migrate diff:*)",
      "Bash(npx tsx:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git commit -m:*)",
      "Bash(git commit -F:*)",
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git fetch:*)",
      "Bash(git remote -v)",
      "Bash(git branch:*)",

      "Bash(ls:*)",
      "Bash(ls -la:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir -p:*)",
      "Bash(wc:*)",
      "Bash(wc -l:*)",
      "Bash(sed -i:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(uname:*)",

      "mcp__ccd_session__mark_chapter",
      "mcp__ccd_session__spawn_task",
      "ScheduleWakeup",
      "ToolSearch",
      "WebFetch",
      "WebSearch",

      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git rebase -i:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git commit --amend:*)",
      "Bash(git commit --no-verify:*)",

      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",
      "Bash(npm publish:*)",
      "Bash(npm publish)"
    ]
  }
}
