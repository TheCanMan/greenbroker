{
  "name": "greenbroker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--no-experimental-webstorage next dev",
    "build": "NODE_OPTIONS=--no-experimental-webstorage next build",
    "start": "NODE_OPTIONS=--no-experimental-webstorage next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv src/env.cloudflare.d.ts"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.1",
    "@prisma/client": "^5.15.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@react-email/components": "^1.0.11",
    "@stripe/stripe-js": "^3.5.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@t3-oss/env-nextjs": "^0.10.1",
    "@uploadthing/react": "^6.6.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.414.0",
    "next": "15.3.5",
    "react": "^18",
    "react-dom": "^18",
    "react-email": "^5.2.10",
    "recharts": "^2.12.7",
    "resend": "^3.3.0",
    "server-only": "^0.0.1",
    "stripe": "^15.12.0",
    "tailwind-merge": "^2.4.0",
    "uploadthing": "^6.12.0",
    "workerd": "^1.20260425.1",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.3.1",
    "postcss": "^8",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.15.7",
    "typescript": "^5",
    "wrangler": "^4.65.0"
  }
}
