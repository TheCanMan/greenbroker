// ─────────────────────────────────────────────────────────────────────────────
// GreenBroker Prisma Schema
// Database: PostgreSQL via Supabase
// Run: npx prisma generate && npx prisma db push
//
// Naming: every model column is mapped to snake_case via @map(...) so the
// underlying Postgres schema matches the conventions used by:
//   - src/lib/supabase/types.ts (manually maintained Database interface)
//   - supabase/migrations/001_rls_policies.sql (snake_case column refs)
//   - every supabase.from(...).select/insert call in the app
// Keep camelCase Prisma field names + snake_case @map for new fields.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  HOMEOWNER
  CONTRACTOR
  ADMIN
}

enum ContractorTier {
  VERIFIED
  PREFERRED
  ELITE
}

enum ContractorStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
  DISPUTED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  email     String   @unique
  role      Role     @default(HOMEOWNER)
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  phone     String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assessments        HomeAssessment[]
  contractor         Contractor?
  rebateApplications RebateApplication[]
  reviews            Review[]

  @@index([userId])
  @@index([email])
  @@map("profiles")
}

// ─── Home Assessment ──────────────────────────────────────────────────────────

model HomeAssessment {
  id        String  @id @default(cuid())
  profileId String? @map("profile_id")

  zip               String
  state             String?
  countyId          String? @map("county_id")
  electricUtilityId String? @map("electric_utility_id")
  gasUtilityId      String? @map("gas_utility_id")
  squareFootage     Int     @map("square_footage")
  yearBuilt         Int     @map("year_built")
  bedrooms          Int
  bathrooms         Int?

  primaryHeatingFuel String  @map("primary_heating_fuel")
  currentHvacType    String  @map("current_hvac_type")
  hvacAge            Int?    @map("hvac_age")
  currentHvacSeer    Float?  @map("current_hvac_seer")
  currentFurnaceAfue Float?  @map("current_furnace_afue")
  hasGas             Boolean @default(true) @map("has_gas")
  electricPanelAmps  Int?    @map("electric_panel_amps")

  roofOrientation String? @map("roof_orientation")
  roofAge         Int?    @map("roof_age")
  atticRValue     Float?  @map("attic_r_value")

  annualKwh    Int? @map("annual_kwh")
  annualTherms Int? @map("annual_therms")

  householdIncome Int?    @map("household_income")
  amiBracket      String? @map("ami_bracket")

  hasExistingSolar Boolean @default(false) @map("has_existing_solar")
  hasEv            Boolean @default(false) @map("has_ev")
  urgency          String?
  notes            String?

  calcAnnualEnergyCost    Float?   @map("calc_annual_energy_cost")
  calcSavingsPotential    Float?   @map("calc_savings_potential")
  calcAvailableRebates    Float?   @map("calc_available_rebates")
  calcSolarPaybackYears   Float?   @map("calc_solar_payback_years")
  calcRecommendedUpgrades String[] @map("calc_recommended_upgrades")

  photoUrls       String[] @map("photo_urls")
  utilityBillUrls String[] @map("utility_bill_urls")

  /// Phase-2 intake fields (goals, household_size, income_range, assistance,
  /// consents, ownership, occupants, water-heater details, etc.) stored as
  /// JSONB so we don't need a per-field migration. Promote to columns when
  /// we have a real query that needs an index.
  intakeV2        Json?    @map("intake_v2")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  leads   Lead[]

  @@index([profileId])
  @@index([zip])
  @@index([countyId])
  @@index([state])
  @@index([createdAt])
  @@map("home_assessments")
}

// ─── Residential Marketplace Models ──────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  profileId String?  @map("profile_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("users")
}

model HomeProfile {
  id           String   @id @default(cuid())
  assessmentId String?  @map("assessment_id")
  profileId    String?  @map("profile_id")
  address      String?
  city         String?
  state        String?
  county       String?
  zip          String
  homeType     String?  @map("home_type")
  ownership    String?
  yearBuilt    Int?     @map("year_built")
  squareFeet   Int?     @map("square_feet")
  occupants    Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([assessmentId])
  @@index([profileId])
  @@index([zip])
  @@map("home_profiles")
}

model UtilityAccount {
  id             String   @id @default(cuid())
  homeProfileId  String?  @map("home_profile_id")
  utilityType    String   @map("utility_type")
  utilityId      String?  @map("utility_id")
  utilityName    String?  @map("utility_name")
  currentSupplier String? @map("current_supplier")
  accountNumber  String? @map("account_number")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([homeProfileId])
  @@index([utilityId])
  @@map("utility_accounts")
}

model UtilityBill {
  id               String   @id @default(cuid())
  utilityAccountId String?  @map("utility_account_id")
  billUrl          String?  @map("bill_url")
  periodStart      DateTime? @map("period_start")
  periodEnd        DateTime? @map("period_end")
  kwh              Float?
  therms           Float?
  costUsd          Float?   @map("cost_usd")
  parsedJson       Json?    @map("parsed_json")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([utilityAccountId])
  @@map("utility_bills")
}

model ExistingEquipment {
  id            String   @id @default(cuid())
  homeProfileId String? @map("home_profile_id")
  equipmentType String  @map("equipment_type")
  fuelType      String? @map("fuel_type")
  ageYears      Int?    @map("age_years")
  condition     String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([homeProfileId])
  @@index([equipmentType])
  @@map("existing_equipment")
}

model GoalSelection {
  id            String   @id @default(cuid())
  homeProfileId String? @map("home_profile_id")
  goal          String
  priority      Int?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([homeProfileId])
  @@index([goal])
  @@map("goal_selections")
}

model EligibilityProfile {
  id                 String   @id @default(cuid())
  homeProfileId      String?  @map("home_profile_id")
  householdSize      Int?     @map("household_size")
  incomeRange        String?  @map("income_range")
  assistancePrograms String[] @default([]) @map("assistance_programs")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([homeProfileId])
  @@index([incomeRange])
  @@map("eligibility_profiles")
}

model RebateProgram {
  id                          String   @id
  programName                 String   @map("program_name")
  administrator               String
  territory                   String?
  eligibleUpgradeTypes        String[] @default([]) @map("eligible_upgrade_types")
  maxRebate                   String?  @map("max_rebate")
  applicationTiming           String?  @map("application_timing")
  requiresContractor          Boolean  @default(false) @map("requires_contractor")
  requiresIncomeQualification Boolean  @default(false) @map("requires_income_qualification")
  documentsNeeded             String[] @default([]) @map("documents_needed")
  lastVerified                DateTime? @map("last_verified")
  sourceUrl                   String?  @map("source_url")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@index([administrator])
  @@map("rebate_programs")
}

model UpgradeRecommendation {
  id                  String   @id @default(cuid())
  homeProfileId       String?  @map("home_profile_id")
  upgradeType         String   @map("upgrade_type")
  projectCostRange    Json     @map("project_cost_range")
  eligibleRebates     String[] @default([]) @map("eligible_rebates")
  netCostRange        Json     @map("net_cost_range")
  annualSavingsRange  Json     @map("annual_savings_range")
  paybackRange        Json     @map("payback_range")
  confidenceScore     Int      @map("confidence_score")
  paperworkStatus     String   @map("paperwork_status")
  whyRecommended      String   @map("why_recommended")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([homeProfileId])
  @@index([upgradeType])
  @@map("upgrade_recommendations")
}

model Product {
  id                   String   @id
  productName          String   @map("product_name")
  brand                String
  category             String
  energyStarCertified  Boolean  @default(false) @map("energy_star_certified")
  efficiencyMetric     String?  @map("efficiency_metric")
  estimatedPrice       String?  @map("estimated_price")
  eligibleRebates      String[] @default([]) @map("eligible_rebates")
  affiliateUrl         String?  @map("affiliate_url")
  retailer             String?
  modelNumber          String?  @map("model_number")
  warranty             String?
  installationRequired Boolean  @default(false) @map("installation_required")
  bestFor              String?  @map("best_for")
  rankingScore         Int      @default(0) @map("ranking_score")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([rankingScore])
  @@map("products")
}

model ContractorQuote {
  id                  String   @id @default(cuid())
  contractorId        String?  @map("contractor_id")
  homeProfileId       String?  @map("home_profile_id")
  selectedUpgrade     String   @map("selected_upgrade")
  grossCostUsd        Float?   @map("gross_cost_usd")
  eligibleModelNumber String?  @map("eligible_model_number")
  timeline            String?
  licenseInfo         Json?    @map("license_info")
  participatesInRebate Boolean @default(false) @map("participates_in_rebate")
  status              String   @default("draft")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([contractorId])
  @@index([homeProfileId])
  @@map("contractor_quotes")
}

model RebatePacket {
  id                  String   @id @default(cuid())
  homeProfileId       String?  @map("home_profile_id")
  selectedUpgrade     String   @map("selected_upgrade")
  selectedRebateId    String?  @map("selected_rebate_id")
  contractorQuoteId   String?  @map("contractor_quote_id")
  prefilledSummary    Json?    @map("prefilled_summary")
  requiredDocuments   String[] @default([]) @map("required_documents")
  missingItems        String[] @default([]) @map("missing_items")
  submissionInstructions String? @map("submission_instructions")
  status              String   @default("draft")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([homeProfileId])
  @@index([status])
  @@map("rebate_packets")
}

model SupplierOffer {
  id                  String   @id
  supplierName        String   @map("supplier_name")
  licenseNumber       String   @map("license_number")
  commodity           String
  rate                Float
  fixedOrVariable     String   @map("fixed_or_variable")
  termMonths          Int      @map("term_months")
  monthlyFee          Float    @default(0) @map("monthly_fee")
  earlyTerminationFee Float    @default(0) @map("early_termination_fee")
  renewablePercent    Int      @default(0) @map("renewable_percent")
  warnings            String[] @default([])
  /// Public supplier homepage / offer URL — surfaced in UI as "verify at supplier site →"
  url                 String?
  /// Teaser rate $/kWh — only meaningful when fixedOrVariable = "intro_then_variable"
  introRate           Float?    @map("intro_rate")
  introMonths         Int?      @map("intro_months")
  /// Where we verified this offer (PSC list, supplier rate page, etc.)
  sourceUrl           String?   @map("source_url")
  lastVerified        DateTime? @map("last_verified")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([commodity])
  @@index([supplierName])
  @@map("supplier_offers")
}

model SupplierComparison {
  id                    String   @id @default(cuid())
  homeProfileId         String?  @map("home_profile_id")
  utility               String?
  currentSupplier       String?  @map("current_supplier")
  currentRate           Float?   @map("current_rate")
  annualKwh             Int?     @map("annual_kwh")
  desiredPlanType       String?  @map("desired_plan_type")
  riskTolerance         String?  @map("risk_tolerance")
  resultsJson           Json?    @map("results_json")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([homeProfileId])
  @@map("supplier_comparisons")
}

// ─── Contractor ───────────────────────────────────────────────────────────────

model Contractor {
  id        String @id @default(cuid())
  profileId String @unique @map("profile_id")

  businessName String           @map("business_name")
  tier         ContractorTier   @default(VERIFIED)
  status       ContractorStatus @default(PENDING_REVIEW)
  categories   String[]

  // Structured service area (preferred). See src/lib/geo/types.ts → ServiceArea.
  serviceAreaKind      String?  @map("service_area_kind")
  serviceAreaStateCode String?  @map("service_area_state_code")
  serviceAreaCountyIds String[] @default([]) @map("service_area_county_ids")
  serviceAreaMetroId   String?  @map("service_area_metro_id")
  serviceUtilityIds    String[] @default([]) @map("service_utility_ids")

  /// @deprecated — populated only by the legacy ZIP-list intake. The
  /// search API falls back to ZIP scanning when serviceAreaKind IS NULL.
  serviceZips String[] @default([]) @map("service_zips")

  bio     String?
  website String?
  logoUrl String? @map("logo_url")

  mhicLicense       String? @map("mhic_license")
  mhicVerified      Boolean @default(false) @map("mhic_verified")
  hvacLicense       String? @map("hvac_license")
  electricalLicense String? @map("electrical_license")
  plumbingLicense   String? @map("plumbing_license")
  wsscLicense       String? @map("wssc_license")

  certifications   String[]
  meaParticipating Boolean  @default(false) @map("mea_participating")

  insuranceVerified     Boolean   @default(false) @map("insurance_verified")
  backgroundCheckPassed Boolean   @default(false) @map("background_check_passed")
  insuranceExpiry       DateTime? @map("insurance_expiry")

  rating            Float @default(0)
  reviewCount       Int   @default(0) @map("review_count")
  completedProjects Int   @default(0) @map("completed_projects")

  stripeCustomerId    String?             @unique @map("stripe_customer_id")
  subscriptionId      String?             @unique @map("subscription_id")
  subscriptionTier    SubscriptionTier?   @map("subscription_tier")
  subscriptionStatus  SubscriptionStatus? @map("subscription_status")
  subscriptionEndDate DateTime?           @map("subscription_end_date")
  leadCredits         Int                 @default(0) @map("lead_credits")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  leads   Lead[]
  reviews Review[]
  // GIN indexes on service_area_county_ids, service_utility_ids, categories
  // live in supabase/migrations/100_gin_indexes.sql — Prisma can't model
  // GIN indexes on text[] columns directly.

  @@index([status])
  @@index([tier])
  @@index([subscriptionStatus])
  @@index([serviceAreaKind])
  @@index([serviceAreaStateCode])
  @@map("contractors")
}

// ─── Lead ─────────────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  assessmentId String     @map("assessment_id")
  contractorId String     @map("contractor_id")
  status       LeadStatus @default(NEW)

  pricePaid       Float   @map("price_paid")
  stripePaymentId String? @map("stripe_payment_id")

  contactedAt DateTime? @map("contacted_at")
  quotedAt    DateTime? @map("quoted_at")
  closedAt    DateTime? @map("closed_at")
  closedValue Float?    @map("closed_value")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assessment HomeAssessment @relation(fields: [assessmentId], references: [id])
  contractor Contractor     @relation(fields: [contractorId], references: [id])

  @@unique([assessmentId, contractorId])
  @@index([contractorId])
  @@index([assessmentId])
  @@index([status])
  @@map("leads")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id           String @id @default(cuid())
  contractorId String @map("contractor_id")
  profileId    String @map("profile_id")

  rating       Int
  title        String?
  body         String
  verified     Boolean @default(false)
  category     String?
  projectValue Float?  @map("project_value")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id])

  @@index([contractorId])
  @@index([profileId])
  @@map("reviews")
}

// ─── Rebate Application ───────────────────────────────────────────────────────

model RebateApplication {
  id        String @id @default(cuid())
  profileId String @map("profile_id")

  programId   String @map("program_id")
  programName String @map("program_name")

  status ApplicationStatus @default(DRAFT)

  submittedAt DateTime? @map("submitted_at")
  approvedAt  DateTime? @map("approved_at")
  amount      Float?

  notes        String?
  documentUrls String[] @map("document_urls")

  formData Json? @map("form_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
  @@map("rebate_applications")
}

// ─── Stripe Events ────────────────────────────────────────────────────────────

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")
  data        Json

  @@map("stripe_events")
}

// ─── Contact Request ─────────────────────────────────────────────────────────

model ContactRequest {
  id String @id @default(cuid())

  name  String
  email String
  phone String?

  message    String
  categories String[]
  zip        String

  contractorId String? @map("contractor_id")

  responded   Boolean   @default(false)
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contractorId])
  @@index([email])
  @@map("contact_requests")
}
