// ─────────────────────────────────────────────────────────────────────────────
// GreenBroker Prisma Schema
// Database: PostgreSQL via Supabase
// Run: npx prisma generate && npx prisma db push
//
// Naming: every model column is mapped to snake_case via @map(...) so the
// underlying Postgres schema matches the conventions used by:
//   - src/lib/supabase/types.ts (manually maintained Database interface)
//   - supabase/migrations/001_rls_policies.sql (snake_case column refs)
//   - every supabase.from(...).select/insert call in the app
// Keep camelCase Prisma field names + snake_case @map for new fields.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  HOMEOWNER
  CONTRACTOR
  ADMIN
}

enum ContractorTier {
  VERIFIED
  PREFERRED
  ELITE
}

enum ContractorStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
  DISPUTED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  email     String   @unique
  role      Role     @default(HOMEOWNER)
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  phone     String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assessments        HomeAssessment[]
  contractor         Contractor?
  rebateApplications RebateApplication[]
  reviews            Review[]

  @@index([userId])
  @@index([email])
  @@map("profiles")
}

// ─── Home Assessment ──────────────────────────────────────────────────────────

model HomeAssessment {
  id        String  @id @default(cuid())
  profileId String? @map("profile_id")

  zip               String
  state             String?
  countyId          String? @map("county_id")
  electricUtilityId String? @map("electric_utility_id")
  gasUtilityId      String? @map("gas_utility_id")
  squareFootage     Int     @map("square_footage")
  yearBuilt         Int     @map("year_built")
  bedrooms          Int
  bathrooms         Int?

  primaryHeatingFuel String  @map("primary_heating_fuel")
  currentHvacType    String  @map("current_hvac_type")
  hvacAge            Int?    @map("hvac_age")
  currentHvacSeer    Float?  @map("current_hvac_seer")
  currentFurnaceAfue Float?  @map("current_furnace_afue")
  hasGas             Boolean @default(true) @map("has_gas")
  electricPanelAmps  Int?    @map("electric_panel_amps")

  roofOrientation String? @map("roof_orientation")
  roofAge         Int?    @map("roof_age")
  atticRValue     Float?  @map("attic_r_value")

  annualKwh    Int? @map("annual_kwh")
  annualTherms Int? @map("annual_therms")

  householdIncome Int?    @map("household_income")
  amiBracket      String? @map("ami_bracket")

  hasExistingSolar Boolean @default(false) @map("has_existing_solar")
  hasEv            Boolean @default(false) @map("has_ev")
  urgency          String?
  notes            String?

  calcAnnualEnergyCost    Float?   @map("calc_annual_energy_cost")
  calcSavingsPotential    Float?   @map("calc_savings_potential")
  calcAvailableRebates    Float?   @map("calc_available_rebates")
  calcSolarPaybackYears   Float?   @map("calc_solar_payback_years")
  calcRecommendedUpgrades String[] @map("calc_recommended_upgrades")

  photoUrls       String[] @map("photo_urls")
  utilityBillUrls String[] @map("utility_bill_urls")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  leads   Lead[]

  @@index([profileId])
  @@index([zip])
  @@index([countyId])
  @@index([state])
  @@index([createdAt])
  @@map("home_assessments")
}

// ─── Contractor ───────────────────────────────────────────────────────────────

model Contractor {
  id        String @id @default(cuid())
  profileId String @unique @map("profile_id")

  businessName String           @map("business_name")
  tier         ContractorTier   @default(VERIFIED)
  status       ContractorStatus @default(PENDING_REVIEW)
  categories   String[]

  // Structured service area (preferred). See src/lib/geo/types.ts → ServiceArea.
  serviceAreaKind      String?  @map("service_area_kind")
  serviceAreaStateCode String?  @map("service_area_state_code")
  serviceAreaCountyIds String[] @default([]) @map("service_area_county_ids")
  serviceAreaMetroId   String?  @map("service_area_metro_id")
  serviceUtilityIds    String[] @default([]) @map("service_utility_ids")

  /// @deprecated — populated only by the legacy ZIP-list intake. The
  /// search API falls back to ZIP scanning when serviceAreaKind IS NULL.
  serviceZips String[] @default([]) @map("service_zips")

  bio     String?
  website String?
  logoUrl String? @map("logo_url")

  mhicLicense       String? @map("mhic_license")
  mhicVerified      Boolean @default(false) @map("mhic_verified")
  hvacLicense       String? @map("hvac_license")
  electricalLicense String? @map("electrical_license")
  plumbingLicense   String? @map("plumbing_license")
  wsscLicense       String? @map("wssc_license")

  certifications   String[]
  meaParticipating Boolean  @default(false) @map("mea_participating")

  insuranceVerified     Boolean   @default(false) @map("insurance_verified")
  backgroundCheckPassed Boolean   @default(false) @map("background_check_passed")
  insuranceExpiry       DateTime? @map("insurance_expiry")

  rating            Float @default(0)
  reviewCount       Int   @default(0) @map("review_count")
  completedProjects Int   @default(0) @map("completed_projects")

  stripeCustomerId    String?             @unique @map("stripe_customer_id")
  subscriptionId      String?             @unique @map("subscription_id")
  subscriptionTier    SubscriptionTier?   @map("subscription_tier")
  subscriptionStatus  SubscriptionStatus? @map("subscription_status")
  subscriptionEndDate DateTime?           @map("subscription_end_date")
  leadCredits         Int                 @default(0) @map("lead_credits")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  leads   Lead[]
  reviews Review[]
  // GIN indexes on service_area_county_ids, service_utility_ids, categories
  // live in supabase/migrations/100_gin_indexes.sql — Prisma can't model
  // GIN indexes on text[] columns directly.

  @@index([status])
  @@index([tier])
  @@index([subscriptionStatus])
  @@index([serviceAreaKind])
  @@index([serviceAreaStateCode])
  @@map("contractors")
}

// ─── Lead ─────────────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  assessmentId String     @map("assessment_id")
  contractorId String     @map("contractor_id")
  status       LeadStatus @default(NEW)

  pricePaid       Float   @map("price_paid")
  stripePaymentId String? @map("stripe_payment_id")

  contactedAt DateTime? @map("contacted_at")
  quotedAt    DateTime? @map("quoted_at")
  closedAt    DateTime? @map("closed_at")
  closedValue Float?    @map("closed_value")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assessment HomeAssessment @relation(fields: [assessmentId], references: [id])
  contractor Contractor     @relation(fields: [contractorId], references: [id])

  @@unique([assessmentId, contractorId])
  @@index([contractorId])
  @@index([assessmentId])
  @@index([status])
  @@map("leads")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id           String @id @default(cuid())
  contractorId String @map("contractor_id")
  profileId    String @map("profile_id")

  rating       Int
  title        String?
  body         String
  verified     Boolean @default(false)
  category     String?
  projectValue Float?  @map("project_value")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id])

  @@index([contractorId])
  @@index([profileId])
  @@map("reviews")
}

// ─── Rebate Application ───────────────────────────────────────────────────────

model RebateApplication {
  id        String @id @default(cuid())
  profileId String @map("profile_id")

  programId   String @map("program_id")
  programName String @map("program_name")

  status ApplicationStatus @default(DRAFT)

  submittedAt DateTime? @map("submitted_at")
  approvedAt  DateTime? @map("approved_at")
  amount      Float?

  notes        String?
  documentUrls String[] @map("document_urls")

  formData Json? @map("form_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
  @@map("rebate_applications")
}

// ─── Stripe Events ────────────────────────────────────────────────────────────

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")
  data        Json

  @@map("stripe_events")
}

// ─── Contact Request ─────────────────────────────────────────────────────────

model ContactRequest {
  id String @id @default(cuid())

  name  String
  email String
  phone String?

  message    String
  categories String[]
  zip        String

  contractorId String? @map("contractor_id")

  responded   Boolean   @default(false)
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contractorId])
  @@index([email])
  @@map("contact_requests")
}
