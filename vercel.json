{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/stripe/webhooks/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/assessments/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/solar-estimate/route.ts": {
      "maxDuration": 20
    },
    "src/app/api/leads/purchase/route.ts": {
      "maxDuration": 20
    }
  },
  "headers": [
    {
      "source": "/api/stripe/webhooks",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/contractors/signup",
      "destination": "/contractors/apply",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-leads",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/rebate-reminders",
      "schedule": "0 9 * * 1"
    }
  ]
}
